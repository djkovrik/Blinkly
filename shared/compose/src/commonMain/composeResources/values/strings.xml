    <!-- Exercising -->
    <string name="block_a">Block A</string>
    <string name="block_a_title">Workplace Warm-up</string>
    <string name="block_a_desc">Perfect for a quick break at your desk. No need to move - just look up from your screen.</string>
    <string name="block_b">Block B</string>
    <string name="block_b_title">Relax and Unwind</string>
    <string name="block_b_desc">A calming evening routine to release tension after a long day of screen time.</string>
    <string name="block_c">Block C</string>
    <string name="block_c_title">The 20-20-20 Express</string>
    <string name="block_c_desc">The golden rule of digital eye care. Use this anytime, anywhere.</string>
    <string name="exercise_blink_break">Blink Break</string>
    <string name="exercise_blink_break_desc">Blink rapidly and gently. This refreshes your tear film and relieves dryness. (You blink less when staring at screens — this resets it!)</string>
    <string name="exercise_near_far_focus">Near-Far Focus</string>
    <string name="exercise_near_far_focus_desc">Hold your thumb 6 inches (15 cm) from your nose. Focus on it. Then, shift your focus to something far away (out a window or across the room). Hold for a few seconds each time.</string>
    <string name="exercise_diagonal_gazes">Diagonal Gazes</string>
    <string name="exercise_diagonal_gazes_desc">Keep your head still. Look up to the left, then down to the right. Repeat on the other side: up to the right, down to the left.</string>
    <string name="exercise_figure_eight">Figure 8</string>
    <string name="exercise_figure_eight_desc">Imagine a giant figure 8 (∞) lying on its side in front of you. Slowly trace it with your eyes. Go one direction, then switch.</string>
    <string name="exercise_clock_rolls">Clock Rolls</string>
    <string name="exercise_clock_rolls_desc">Imagine a large clock face. Slowly move your eyes from 12 → 3 → 6 → 9 → back to 12. Keep your head still.</string>
    <string name="exercise_palming">Palming</string>
    <string name="exercise_palming_desc">Rub your hands together to warm them. Gently cup your palms over your closed eyes (fingers crossed on your forehead). Make sure no light gets in. Breathe deeply and imagine pure blackness or a peaceful scene.</string>
    <string name="exercise_twenty_x3">20-20-20 Rule</string>
    <string name="exercise_twenty_x3_desc">Every 20 minutes, look at something at least 20 feet (6 meters) away for at least 20 seconds.</string>

