    <string name="onboarding_initial_setup_twenty_title">The 20-20-20 rule</string>
    <string name="onboarding_initial_setup_twenty_description">Every 20 minutes, take a 20-second break and look at something about 20 feet (6 meters) away. This helps your eyes relax and reduce strain.</string>
